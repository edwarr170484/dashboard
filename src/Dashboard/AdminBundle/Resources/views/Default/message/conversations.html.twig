{% extends 'DashboardAdminBundle:Common:adminbase.html.twig' %}

{% block title %}{% trans %} Панель управления - Сообщения для технической поддержки{% endtrans %}{% endblock %}

{% block body %}
<div id="content" class="content">
    <ol class="breadcrumb pull-right">
        <li><a href="{{ path('admin_main') }}">Главная</a></li>
        <li class="active">Техническая поддержка</li>
    </ol>
    <h1 class="page-header">Техническая поддержка</h1>
    <div class="row">
        <div class="col-md-12 ui-sortable">
            {% for flashMessage in app.session.flashbag.get('notice') %}
                <div class="notice-message">
                    {{ flashMessage | raw }}
                </div>                             
            {% endfor %}
            <div data-sortable-id="table-basic-7" class="panel panel-inverse">
                <div class="panel-heading ui-sortable-handle">
                    <div class="btn-group pull-right">
                        <button class="btn btn-success btn-xs" type="button">Действия</button>
                        <button data-toggle="dropdown" class="btn btn-success btn-xs dropdown-toggle" type="button">
                            <span class="caret"></span>
                        </button>
                        <ul role="menu" class="dropdown-menu">
                            <li><a href="#" onclick="if(confirm('Вы действительно хотите удалить отмеченные диалоги?')){$('#actionForm').val('delete');document.deleteSelected.submit();} else return false;">Удалить отмеченные</a></li>
                        </ul>
                    </div>
                    <h4 class="panel-title">Техническая поддержка</h4>
                </div>
                <div class="panel-body">
                    {% if conversations | length > 0 %}
                        <form action="{{ path('admin_conversations')}}" method="POST" name="deleteSelected" id="deleteSelected">
                            <input name="actionForm" value="" type="hidden" id="actionForm"/>
                            <table class="table table-bordered table-messages">
                                <thead>
                                    <tr>
                                        <th><input type="checkbox" class="selectAllItems" /></th>
                                        <th>Диалог</th>
                                        <th>Сообщение</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for conversation in conversations %}
                                        {% set newMessages = 0 %}
                                        {% set lastMessage = 0 %}
                                        {% set isActive = 0 %}
                                        {% for message in conversation.messages %}
                                            {% if message.userTo.id == user.id and message.isNew == 1 and message.userOwner.id == user.id %}
                                                {% set newMessages = newMessages + 1 %}
                                                {% set isActive = 1 %}
                                            {% endif %}
                                            {% set lastMessage = message %}
                                        {% endfor%}
                                        <tr>
                                            <td><input name="conversationIds[]" value="{{ conversation.id }}" type="checkbox" class="checkbox-item" /></td>
                                            <td>
                                                <div style="display:flex;justify-content:flex-start;align-items:center">
