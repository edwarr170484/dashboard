                                                            </svg>
                                                        {% endif %}
                                                    {% else %}
                                                        {% if conversation.userOne %}
                                                            {% if conversation.userOne.userinfo.avatar %}
                                                                <img src="{{ asset('bundles/images/users/avatars/' ~ conversation.userOne.userinfo.avatar) }}" alt="" title="" style="width: 64px;" />
                                                            {% else %}
                                                                <svg width="50" height="50" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                                    <circle cx="32" cy="32" r="32" fill="#F5AA01"/>
