{% use 'DashboardCommonBundle:Common:icons.html.twig' %}
<header>
    <div class="headerlocale">
        <div class="container">
            <div class="row">
            <div class="col-lg-12">
                <div class="headerMenu">
                    {% if user %}
                        <div class="header-locale">
                            <div class="select-languages">
                                <div class="select-language">
                                    <div class="select-language-option-main">
                                        {% for item in locales %}
                                            {% if item.id == locale.id %}
                                                {% if item.isDefault %}
                                                    <a href="javascript:void(0)" class="locale-change" style="background:url('{{ asset('bundles/Default/img/flags/' ~ item.country)}}') 0 50% no-repeat;-webkit-background-size: 30px auto;background-size: 30px auto;">{{ item.name }} {{ block('arrow') }}</a>
                                                {% else %}
                                                    <a href="javascript:void(0)" class="locale-change" style="background:url('{{ asset('bundles/Default/img/flags/' ~ item.country)}}') 0 50% no-repeat;-webkit-background-size: 30px auto;background-size: 30px auto;">{{ item.name }} {{ block('arrow') }}</a>
                                                {% endif %}
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                    <div class="select-language-options">
                                        {% for item in locales %}
                                            {% if item.id != locale.id %}
                                                <div class="select-language-option">
                                                    {% if item.isDefault %}
                                                        <a href="{{ uri }}" class="locale-change" style="background:url('{{ asset('bundles/Default/img/flags/' ~ item.country)}}') 0 50% no-repeat;-webkit-background-size: 30px auto;background-size: 30px auto;">{{ item.name }}</a>
                                                    {% else %}
                                                        <a href="/{{ item.code }}{{ uri }}" class="locale-change" style="background:url('{{ asset('bundles/Default/img/flags/' ~ item.country)}}') 0 50% no-repeat;-webkit-background-size: 30px auto;background-size: 30px auto;">{{ item.name }}</a>
                                                    {% endif %}
                                                </div>  
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                            <div class="select-location">
                                <a data-toggle="modal" data-target="#regionModal" class="top-select-region">
                                    {% if sessionCity %}
                                        {{ sessionCity.name }}
                                    {% else %}
                                        {% if sessionRegion %}
                                            {{ sessionRegion.name }}
                                        {% else %}
                                            {% trans %}Вся Испания{% endtrans %}
                                        {% endif %}
                                    {% endif %}
                                </a>            
                            </div>
                        </div>
                        <div class="hidden-sm hidden-xs">
                            <ul class="list-unstyled list-inline loginned-top-info">
                                <li>
                                    {% if app.user.userinfo.firstname or  app.user.userinfo.lastname %}
                                        {% if  app.request.locale == 'lv' %}
                                            <a href="{{path('account')}}">{{ app.user.userinfo.firstname }} {{app.user.userinfo.lastname}}</a>
                                        {% else %}
                                            <a href="{{path('accountLocale',{'_locale' : app.request.locale})}}">{{ app.user.userinfo.firstname }} {{app.user.userinfo.lastname}}</a>
                                        {% endif %}
                                    {% elseif app.user.vkID %}
                                        {% if  app.request.locale == 'lv' %}
                                            <a href="{{path('account')}}">{{ app.user.vkID }}</a>
                                        {% else %}
                                            <a href="{{path('accountLocale',{'_locale' : app.request.locale})}}">{{ app.user.vkID }}</a>
                                        {% endif %}
                                    {% elseif app.user.fbID %} 
                                        {% if  app.request.locale == 'lv' %}
                                            <a href="{{path('account')}}">{{ app.user.fbID }}</a>
                                        {% else %}
                                            <a href="{{path('accountLocale',{'_locale' : app.request.locale})}}">{{ app.user.fbID }}</a>
                                        {% endif %}
                                    {% endif %}
                                </li>
                                <li>
                                    <a href="{{path('logout')}}" class="top-info-logout">
                                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-left: 1.9rem;">
                                            <path d="M7 19H3C2.46957 19 1.96086 18.7893 1.58579 18.4142C1.21071 18.0391 1 17.5304 1 17V3C1 2.46957 1.21071 1.96086 1.58579 1.58579C1.96086 1.21071 2.46957 1 3 1H7" stroke="#616161" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M14 15L19 10L14 5" stroke="#616161" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M19 10H7" stroke="#616161" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </a>
                                </li>
                            </ul>
                        </div>
                        {% else %}
                            <div class="header-locale">
                                <div class="select-languages">
                                    <div class="select-language">
                                        <div class="select-language-option-main">
                                            {% for item in locales %}
                                                {% if item.id == locale.id %}
                                                    {% if item.isDefault %}
                                                        <a href="javascript:void(0)" class="locale-change" style="background:url('{{ asset('bundles/Default/img/flags/' ~ item.country)}}') 0 50% no-repeat;-webkit-background-size: 30px auto;background-size: 30px auto;">{{ item.name }} {{ block('arrow') }}</a>
                                                    {% else %}
                                                        <a href="javascript:void(0)" class="locale-change" style="background:url('{{ asset('bundles/Default/img/flags/' ~ item.country)}}') 0 50% no-repeat;-webkit-background-size: 30px auto;background-size: 30px auto;">{{ item.name }} {{ block('arrow') }}</a>
                                                    {% endif %}
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                        <div class="select-language-options">
                                            {% for item in locales %}
                                                {% if item.id != locale.id %}
                                                    <div class="select-language-option">
                                                        {% if item.isDefault %}
                                                            <a href="{{ uri }}" class="locale-change" style="background:url('{{ asset('bundles/Default/img/flags/' ~ item.country)}}') 0 50% no-repeat;-webkit-background-size: 30px auto;background-size: 30px auto;">{{ item.name }}</a>
                                                        {% else %}
                                                            <a href="/{{ item.code }}{{ uri }}" class="locale-change" style="background:url('{{ asset('bundles/Default/img/flags/' ~ item.country)}}') 0 50% no-repeat;-webkit-background-size: 30px auto;background-size: 30px auto;">{{ item.name }}</a>
                                                        {% endif %}
                                                    </div>  
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                                <div class="select-location">
                                    <a data-toggle="modal" data-target="#regionModal" class="top-select-region">
                                        {% if sessionCity %}
                                            {{ sessionCity.name }}
                                        {% else %}
                                            {% if sessionRegion %}
                                                {{ sessionRegion.name }}
                                            {% else %}
                                                {% trans %}Вся Испания{% endtrans %}
                                            {% endif %}
                                        {% endif %}
                                    </a>            
                                </div>
                            </div>
                            <div class="hidden-sm hidden-xs">
                                <ul class="list-unstyled list-inline">
                                    {% if  app.request.locale == 'lv' %}   
                                        <li><a href="{{path('login')}}">{% trans %}Pierakstieties{% endtrans %}</a><div class="hover-border"></div></li>
                                        <li> / </li>
                                        <li><a href="{{path('register')}}">{% trans %}Reģistrācijas{% endtrans %}</a><div class="hover-border"></div></li>
                                    {% else %}
                                        <li><a href="{{path('loginLocale',{'_locale' : app.request.locale})}}">{% trans %}Pierakstieties{% endtrans %}</a></a><div class="hover-border"></div></li>
                                        <li> / </li>
                                        <li><a href="{{path('registerLocale',{'_locale' : app.request.locale})}}">{% trans %}Reģistrācijas{% endtrans %}</a></a><div class="hover-border"></div></li>
                                    {% endif %}
                                </ul>
                            </div>
                        {% endif %} 
                </div>
            </div>
        </div>
    </div>
    </div>
    <div class="container">
        <div class="row header-functions">
            <div class="col-lg-3 col-md-3 siteLogo">
                <div class="siteLogoImage">
