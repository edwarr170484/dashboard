                                        <li><a href="" style="font-family:'GothamProBold'">Разместить рекламу</a></li>
                                    </ul>  
                                </div>
                        </div>
        </div>
        {% for flashMessage in app.session.flashbag.get('notice_header') %}
            <div class="notice-message">
                {{ flashMessage | raw }}
            </div>                             
        {% endfor %}
    </div>
    <div class="addAdvertButtonMobile hidden-lg hidden-md">
        {% if  locale.isDefault %}
            {% if app.user %}
                <a href="{{path('addproduct')}}">
                    {{ block('svgAddAdvertMobile') }}
                </a>
            {% else %}
                <a href="{{path('login')}}">
                    {{ block('svgAddAdvertMobile') }}</a>
             {% endif %}
        {% else %}
            {% if app.user %}
                <a href="{{path('addproductLocale',{'_locale' : app.request.locale})}}">{{ block('svgAddAdvertMobile') }}</a>
            {% else %}
                <a href="{{path('loginLocale',{'_locale' : app.request.locale})}}">{{ block('svgAddAdvertMobile') }}</a>
            {% endif %}
        {% endif %}
