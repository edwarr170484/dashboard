                    <li><a href="">Автодома</a><div class="hover-border"></div></li>
                    <li class="submenu">
                        <a href="">Коммерческие
                            <div class="shadowBlock"></div>
                        </a>
                        <div class="hover-border"></div>
                        <div class="siteMainSubmenu">
                            <ul class="list-unstyled">
                                <li><a href="">Автобусы</a></li>
                                <li><a href="">Грузовики</a></li>
                                <li><a href="">Тягачи</a></li>
                                <li><a href="">Прицепы&nbsp;и&nbsp;полуприцепы</a></li>
                                <li><a href="">Сельскохозяйственная</a></li>
                                <li><a href="">Строительная&nbsp;и&nbsp;дорожная</a></li>
                            </ul>
                            <ul class="list-unstyled">
                                <li><a href="">Погрузчики</a></li>
                                <li><a href="">Автокраны</a></li>
                                <li><a href="">Экскаваторы</a></li>
                                <li><a href="">Бульдозеры</a></li>
                                <li><a href="">Смопогрузчики</a></li>
                                <li><a href="">Коммунальная</a></li>
                            </ul>
                        </div>
                    </li>
                    <li class="submenu">
                        <a href="">Услуги<div class="shadowBlock"></div></a>
                        <div class="hover-border"></div>
                        <div class="siteMainSubmenu">
                            <ul class="list-unstyled">
                                <li><a href="">Дилеры</a></li>
                                <li><a href="">Страхование</a></li>
                                <li><a href="">Кредитование</a></li>
                                <li><a href="">Сервисные&nbsp;центры</a></li>
                            </ul>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="col-lg-3 col-md-3 header-add-button-block hidden-sm hidden-xs">
                            {% if locale.isDefault %}
                                {% if app.user %}
                                    <a href="{{path('addproduct')}}" class="header-add-button pull-right">
                                        {{ block('svgAddAdvert') }}
                                    </a>
                                {% else %}
                                    <a href="{{path('login')}}" class="header-add-button pull-right">
                                        {{ block('svgAddAdvert') }}</a>
                                {% endif %}
                            {% else %}
                                {% if app.user %}
                                    <a href="{{path('addproductLocale',{'_locale' : app.request.locale})}}" class="header-add-button pull-right">{{ block('svgAddAdvert') }}</a>
                                {% else %}
                                    <a href="{{path('loginLocale',{'_locale' : app.request.locale})}}" class="header-add-button pull-right">{{ block('svgAddAdvert') }}</a>
                                {% endif %}
                            {% endif %}
            </div>
            <div class="siteMenuGamburgerMenu">
                            <button onclick='$(".siteMenuGamburgerMenu").hide();'>
                                <svg width="26" height="15" viewBox="0 0 26 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22 6.19549H0V8.20271H22V6.19549Z" fill="#EB840B"/>
                                <path d="M26 12.2171H0V14.2244H26V12.2171Z" fill="#EB840B"/>
                                <path d="M26 0.173828H0V2.18105H26V0.173828Z" fill="#EB840B"/>
                                </svg>
                            </button>
                            <div class="siteMenuGamburgerItem">
                                <div class="siteMenuGamburgerHeader">{% trans %}Легковые{% endtrans %}</div>
                                <ul class="list-unstyled">
                                    <li><a href="">С пробегом</a></li>
                                    <li><a href="">Новые</a></li>
                                    <li><a href="">Дилеры</a></li>
                                </ul>
                            </div>
                            <div class="siteMenuGamburgerItem">
                                <div class="siteMenuGamburgerHeader">{% trans %}Мотоциклы{% endtrans %}</div>
                                <ul class="list-unstyled">
                                    <li><a href="">Мотоциклы</a></li>
                                    <li><a href="">Скутеры</a></li>
                                    <li><a href="">Мотовездеходы</a></li>
                                    <li><a href="">Снегоходы</a></li>
                                </ul>
                            </div>
                            <div class="siteMenuGamburgerItem">
                                <div class="siteMenuGamburgerHeader">{% trans %}Автодома{% endtrans %}</div>
                                <ul class="list-unstyled">
                                    <li><a href="">Автосалоны-пикапы</a></li>
                                    <li><a href="">Каюты</a></li>
                                    <li><a href="">Настурции</a></li>
                                    <li><a href="">Караваны</a></li>
                                    <li><a href="">Фургоны</a></li>
                                    <li><a href="">Integral</a></li>
                                    <li><a href="">Полуинтеграл</a></li>
                                    <li><a href="">Другие автодома</a></li>
                                </ul>        
                            </div>
                            <div class="siteMenuGamburgerItem">
                                <div class="siteMenuGamburgerHeader">{% trans %}Коммерческие{% endtrans %}</div>
                                <ul class="list-unstyled">
                                    <li><a href="">Автобусы</a></li>
                                    <li><a href="">Грузовики</a></li>
                                    <li><a href="">Тягачи</a></li>
                                    <li><a href="">Прицепы и полуприцепы</a></li>
                                    <li><a href="">Сельскохозяйственная</a></li>
                                    <li><a href="">Строительная и дорожная</a></li>
                                    <li><a href="">Погрузчики</a></li>
                                    <li><a href="">Автокраны</a></li>
                                    <li><a href="">Эскаваторы</a></li>
                                    <li><a href="">Бульдозеры</a></li>
                                    <li><a href="">Самопогрузчики</a></li>
                                    <li><a href="">Коммунальная</a></li>
                                </ul>  
                            </div>
                                <div class="siteMenuGamburgerItem">
                                    <div class="siteMenuGamburgerHeader">{% trans %}Информация{% endtrans %}</div>
                                    <ul class="list-unstyled">
                                        <li><a href="">Дилерам</a></li>
                                        <li><a href="">Автосервисам</a></li>
                                        <li><a href="">Страховым компаниям</a></li>
                                        <li><a href="">Кредитование</a></li>
