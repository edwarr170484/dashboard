                        {% else %}
                            <a href="{{ path('mainLocale',{'_locale' : app.request.locale}) }}">
                                <img src="{{ asset('bundles/images/site/') }}{{ settings.siteLogo }}" alt="" title="" />
                            </a>
                        {% endif %}
                    {% endif %}
                </div>
                <div class="headerFunctions">
                    <div class="siteMenuMobileLogin hidden-lg hidden-md">
                        {% if  locale.isDefault %}   
