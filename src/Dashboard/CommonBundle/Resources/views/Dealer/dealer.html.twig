                                                        <div class="filtersFromTo">
                                                            <input name="categoryPriceStart[]" value="" placeholder="Цена от" />
                                                            <input name="categoryPriceEnd[]" value="" placeholder="до" />
                                                        </div>
                                                    </div>  
                                                {% endif %}
