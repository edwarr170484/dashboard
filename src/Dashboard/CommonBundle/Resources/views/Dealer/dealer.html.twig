                                    {% for category in categories %}
                                        <li role="presentation" {% if i == 1 %}class="active"{% endif %}>
                                            <a href="#categoryFilters{{ category.id }}" aria-controls="home" role="tab" data-toggle="tab">
                                                {{ category.image |raw }}
                                                <span>
                                                    {% if category.translations | length > 0 %}
                                                        {% for translation in category.translations %}
                                                            {% if translation.locale.id == locale.id %}
                                                                {{ translation.value }}
                                                            {% endif %}
                                                        {% endfor %}
                                                    {% else %}        
                                                        {{ category.title}}
                                                    {% endif %}
                                                </span><div class="shadowBlock"></div></a>
                                        </li>
                                        {% set i = i + 1 %}
                                    {% endfor %}
                                </ul>
                                <div class="tab-content">
                                    {% set i = 1 %}
                                    {% for category in categories %}
                                        <div role="tabpanel" class="tab-pane {% if i == 1 %}active{% endif %}" id="categoryFilters{{ category.id }}">
                                            <div class="row">
                                                <div class="col-lg-6 col-md-6 static-filters hidden-sm hidden-xs">
                                                    <div class="filter">
                                                        <input name="searchNew" type="checkbox" value="1" class="custom-checkbox" /> {% trans %}Новые авто{% endtrans %}
                                                    </div>
                                                    <div class="filter">
                                                        <input name="searchProbeg" type="checkbox" value="1" class="custom-checkbox" /> {% trans %}С пробегом{% endtrans %}
                                                    </div>
                                                </div>
                                                {% if category.filters %}
                                                    {% for filter in category.filters %}
                                                        <div class="col-lg-3 col-md-3">
                                                            {% set filterName = '' %}
                                                            {% if filter.translations | length > 0 %}
                                                                        {% for translation in filter.translations %}
                                                                            {% if translation.locale.id == locale.id %}
                                                                                {% set filterName = translation.value %}
                                                                            {% endif %}
                                                                        {% endfor %}
                                                                    {% else %}    
                                                                        {% set filterName = filter.name %}}
                                                                    {% endif %}
                                                            <select name="1" class="custom-select" id="filter[]" multiple="multiple" placeholder="{{ filterName }}">
                                                                {% if filter.values | length > 0 %}
                                                                    {% for filterValue in filter.values %}
                                                                        <option value="{{ filterValue.id }}">
                                                                        {% if filterValue.translations | length > 0 %}
                                                                            {% for translation in filterValue.translations %}
                                                                                {% if translation.locale.id == locale.id %}
                                                                                    {{ translation.value }}
                                                                                {% endif %}
                                                                            {% endfor %}
                                                                        {% else %}        
                                                                            {{ filterValue.value}}
                                                                        {% endif %}
                                                                        </option>
                                                                    {% endfor %}
                                                                {% endif %}
                                                            </select>
                                                        </div>
                                                    {% endfor %}
                                                {% endif %}
