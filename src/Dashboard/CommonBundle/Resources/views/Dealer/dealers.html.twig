                            <li><a href="" class="active">{% trans %}Все{% endtrans %}</a></li>
                            <li><a href="">{% trans %}Новые{% endtrans %}</a></li>
                            <li><a href="">{% trans %}С пробегом{% endtrans %}</a></li>
                        </ul>
                    </div>
