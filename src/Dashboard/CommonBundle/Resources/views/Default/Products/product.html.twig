                    <div class="categorySpecialAdvertsHeader">
                        <h3>{% trans %}Новые автомобили от дилеров{% endtrans %}</h3>
                        <div class="categorySpecialAdvertsHeaderNew">
                            <a href="">{% trans %}Все предложения{% endtrans %}</a>
