                                                    </svg>
                                                    {% trans %}Сообщить другу{% endtrans %}
                                                </a>
                                            {% endif %}
                                            
                                        </li>
                                        <li role="presentation">
                                            {% if app.user %}
                                            <a data-toggle="modal" data-target="#complaintMessageModal" href="">
                                                <svg width="24" height="23" viewBox="0 0 24 23" fill="none" xmlns="http://www.w3.org/2000/svg">
