                                                        <path d="M25 3L13 11L1 3" stroke="#616161" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                    </svg>
                                                    {% trans %}Сообщить другу{% endtrans %}
                                                </a>
                                            {% else %}
                                                <a href="{{ path('login') }}">
                                                    <svg width="26" height="22" viewBox="0 0 26 22" fill="none" xmlns="http://www.w3.org/2000/svg">
