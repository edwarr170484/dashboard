{% extends 'DashboardCommonBundle:Common:base.html.twig' %}

{% block body %}
<nav class="breadscrumbsBlock">
      <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <ul class="list-unstyled list-inline breadscrumbs">
                    {% if locale.isDefault %}
                        <li><a href="{{ path('main') }}">{% trans %}Главная{% endtrans %}</a></li>
                        <li>/</li>
                    {% else %}
                        <li><a href="{{ path('mainLocale',{'_locale' : app.request.locale}) }}">{% trans %}Главная{% endtrans %}</a></li>
                        <li>/</li>
                    {% endif %}
                    {% if  locale.isDefault %}
                        <li><a href="{{ path('addAdvert', {'_locale' : locale.code}) }}">
                    {% else %}
                        <li><a href="{{ path('addAdvertLocale', {'_locale' : locale.code}) }}">
                    {% endif %}
                        {% trans %}Добавить объявление{% endtrans %}
                    </a></li>
                </ul>
            </div>
        </div>
      </div>
</nav>  
<div class="container" id="addAdvertStep">
    <div class="row content-row">
        <div class="col-lg-9 col-md-9 left-column">
                <div class="content-block-header">
                    <h1>{% trans %}Выберите категорию{% endtrans %}</h1>
                </div>
                {% if categories %}
                    <div class="mainPageFiltersTabs category-filters addAdvert">
                        <ul class="nav nav-tabs" role="tablist">
                            {% set i = 1 %}
                            {% for category in categories %}
                                <li role="presentation" {% if i == 1 %}class="active"{% endif %}>
                                    <a href="#category{{ category.id }}" aria-controls="home" role="tab" data-toggle="tab" class="block">
                                        {% if category.image %}
                                            {{ category.image | raw }}
                                        {% endif %}
                                        <span class="block">
                                            {% if category.translations | length > 0 %}
                                                {% for translation in category.translations %}
                                                    {% if translation.locale.id == locale.id %}
                                                        {{ translation.value }}
                                                    {% endif %}
                                                {% endfor %}
                                            {% else %}        
                                                {{ category.title}}
                                            {% endif %}
                                        </span><div class="shadowBlock"></div></a>
                                </li>
                                {% set i = i + 1 %}
                            {% endfor %}
                        </ul>
                        <div class="tab-content">
                            {% set i = 1 %}
                            {% for category in categories %}
                                <div role="tabpanel" class="tab-pane {% if i == 1 %}active{% endif %}" id="category{{ category.id }}">
                                    {% if category.children %}
                                        <div class="row">
                                            <div class="col-lg-12">
                                                <div class="searchCategoryFiled">
                                                    <input type="text" placeholder="{% trans %}Выберите марку{% endtrans %}"/>
                                                </div>
                                                <div class="mainPageAutoList">
                                                    <ul class="list-unstyled list-inline justLinks">
                                                        {% for child in category.children %}
                                                            <li>
                                                                <a href="javascript:void(0)" onclick="getStep11({{ child.id }}, '{{ locale.code }}')">
                                                                {% if child.translations | length > 0 %}
                                                                    {% for translation in child.translations %}
                                                                        {% if translation.locale.id == locale.id %}
                                                                            {{ translation.value }}
                                                                        {% endif %}
                                                                    {% endfor %}
                                                                {% else %}        
                                                                    {{ child.title}}
                                                                {% endif %}
                                                                </a>
                                                            </li>
                                                        {% endfor %}
                                                    </ul>
                                                </div>
                                            </div>
                                            <div class="col-lg-12 addAdvertFiltersButtons">
                                                <div class="mainPageFiltersShowResults">
                                                    <button>{% trans %}Показать все марки{% endtrans %}</button>
                                                </div>
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                                {% set i = i + 1 %}
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
        </div>
        <div class="col-lg-3 col-md-3 right-column hidden-sm hidden-xs" id="bannersSticky">
            <div class="addAdvertStepsBlock">
                <div class="addAdvertStepsBlockHeader">{% trans %}Шаги{% endtrans %} 1/5</div>
                <div class="addAdvertStepsBlockInner">
                    <ul class="list-unstyled addAdvertSteps">
                        <li class="active">
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M11 21C16.5228 21 21 16.5228 21 11C21 5.47715 16.5228 1 11 1C5.47715 1 1 5.47715 1 11C1 16.5228 5.47715 21 11 21Z" stroke="#ABABAB" stroke-linejoin="round"/>
                                <path d="M5.66699 11L9.00033 14.3333L16.3337 7" stroke="#ABABAB" stroke-linejoin="round"/>
                            </svg>
                            <a href="javascript:void(0)">{% trans %}Выбор автомобиля{% endtrans %}</a>
                        </li>
                        <li>
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M11 21C16.5228 21 21 16.5228 21 11C21 5.47715 16.5228 1 11 1C5.47715 1 1 5.47715 1 11C1 16.5228 5.47715 21 11 21Z" stroke="#ABABAB" stroke-linejoin="round"/>
                                <path d="M5.66699 11L9.00033 14.3333L16.3337 7" stroke="#ABABAB" stroke-linejoin="round"/>
                            </svg>
                            <a href="javascript:void(0)">{% trans %}Внешний вид{% endtrans %}</a>
                        </li>
                        <li>
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M11 21C16.5228 21 21 16.5228 21 11C21 5.47715 16.5228 1 11 1C5.47715 1 1 5.47715 1 11C1 16.5228 5.47715 21 11 21Z" stroke="#ABABAB" stroke-linejoin="round"/>
                                <path d="M5.66699 11L9.00033 14.3333L16.3337 7" stroke="#ABABAB" stroke-linejoin="round"/>
                            </svg>
                            <a href="javascript:void(0)">{% trans %}Комплектация{% endtrans %}</a>
                        </li>
                        <li>
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M11 21C16.5228 21 21 16.5228 21 11C21 5.47715 16.5228 1 11 1C5.47715 1 1 5.47715 1 11C1 16.5228 5.47715 21 11 21Z" stroke="#ABABAB" stroke-linejoin="round"/>
                                <path d="M5.66699 11L9.00033 14.3333L16.3337 7" stroke="#ABABAB" stroke-linejoin="round"/>
                            </svg>
                            <a href="javascript:void(0)">{% trans %}Состояние и цена{% endtrans %}</a>
                        </li>
                        <li>
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M11 21C16.5228 21 21 16.5228 21 11C21 5.47715 16.5228 1 11 1C5.47715 1 1 5.47715 1 11C1 16.5228 5.47715 21 11 21Z" stroke="#ABABAB" stroke-linejoin="round"/>
                                <path d="M5.66699 11L9.00033 14.3333L16.3337 7" stroke="#ABABAB" stroke-linejoin="round"/>
                            </svg>
                            <a href="javascript:void(0)">{% trans %}Контактные данные{% endtrans %}</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}


