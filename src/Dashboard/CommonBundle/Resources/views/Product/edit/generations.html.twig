{% if boards | length > 0 %}
    <td>
        <div class="advertFiltersItemName">{% trans %}Поколение{% endtrans %}</div>
    </td>
    <td>
        <div class="advertFiltersItemValue">
            <div class="addAdvertGenerations">
                {% for board in boards %}
                    <div class="addAdvertGeneration {% if board.generation.id == advertInfo.info.generation.id %}active{% endif %}" onclick="getGenerationEngineEdit({{board.generation.id }},{{ advertInfo.id }}, $(this))">
                        <img src="{{ asset('bundles/images/category/generation/' ~ board.image) }}" alt="" title="" />
                        <div class="addAdvertGenerationName">{{ board.generation.name }}</div>
                        <div class="addAdvertGenerationYears">{{ board.generation.yearFrom }} - {{ board.generation.yearTo }}</div>
                        <input name="generation[]" type="radio" class="hidden-radio-parameter" value="{{ board.generation.id }}"  {% if board.generation.id == advertInfo.info.generation.id %}checked="checked"{% endif %}/>
                    </div>    
                {% endfor %}
            </div>
        </div>
    </td>
{% endif %}
