{% if modifications | length > 0 %}
    <td><div class="advertFiltersItemName">{% trans %}Модификация{% endtrans %}</div></td>
    <td>
        <div class="advertFiltersItemValue">
            <div class="addAdvertModifications">
                {% for modification in modifications %}
                    <div class="addAdvertModification {% if modification.id == advertInfo.info.modification.id %}active{% endif %}" onclick="$(this).parent().find('.addAdvertModification').each(function(){$(this).removeClass('active');});$(this).addClass('active');$('.cookieAlertButton.nextStep').removeClass('hide');">
                        <div class="addAdvertModificationParam power">{{ modification.power }} {% trans %}л.с.{% endtrans %}</div>
                        <div class="addAdvertModificationParam size">{{ modification.size }}</div>
                        <div class="addAdvertModificationParam label">{{ modification.label }}</div>
                        <input name="modification[]" type="radio" class="hidden-radio-parameter" value="{{ modification.id }}" {% if modification.id == advertInfo.info.modification.id %}checked="checked"{% endif %} />
                        {% if modification.id == advertInfo.info.modification.id %}
                            <script>$('.cookieAlertButton.nextStep').removeClass('hide');</script>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </td>
{% endif %}