{% extends 'DashboardCommonBundle:Common:base.html.twig' %}
{% use 'DashboardCommonBundle:Common:icons.html.twig' %}

{% block title %}{% trans %}Lietotāja konts{% endtrans %}{% endblock %}

{% block topbanner %}
    <div class="topBanner">
        <div class="container">
            <div class="row">
                <div class="col-md-12 topBannerBlock">
                    {{ render(controller('DashboardCommonBundle:Default:getBanners',{'position' : 'toppage'})) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block body %}
<nav class="breadscrumbsBlock">
      <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <ul class="list-unstyled list-inline breadscrumbs">
                    {% if locale.isDefault %}
                        <li><a href="{{ path('main') }}">{% trans %}Главная{% endtrans %}</a></li>
                        <li>/</li>
                    {% else %}
                        <li><a href="{{ path('mainLocale',{'_locale' : app.request.locale}) }}">{% trans %}Главная{% endtrans %}</a></li>
                        <li>/</li>
                    {% endif %}
                    {% if  locale.isDefault %}
                        <li><a href="{{ path('account', {'_locale' : locale.code}) }}">
                    {% else %}
                        <li><a href="{{ path('accountLocale', {'_locale' : locale.code}) }}">
                    {% endif %}
                        {% trans %}Личный кабинет{% endtrans %}
                    </a></li>
                </ul>
            </div>
        </div>
      </div>
</nav> 
<div class="container">
    <div class="row content-row aligned">
        <div class="col-lg-3 col-md-3">
            <div class="account-block-header"><h1>{% trans %}Личный кабинет{% endtrans %}</h1></div>
        </div>
        <div class="col-lg-9 col-md-9">
            <div class="accountBlockHeader">
                <div class="account-block-header"><h1>{% trans %}<b>Мои</b> объявления{% endtrans %}</h1></div>
                {% if countProducts > 4 %}
                    <div class="account-block-header-label">
                        {% if locale.isDefault %}
                            <a href="{{ path('account_products') }}">{% trans %}показать все{% endtrans %} ({{ countProducts }})</a>
                        {% else %}
                            <a href="{{ path('account_productsLocale',{'_locale' : locale.code}) }}">{% trans %}показать все{% endtrans %} ({{ countProducts }})</a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="row content-row">
        {{ render(controller('DashboardCommonBundle:Account:getSidebar')) }}
        <div class="col-ld-9 col-md-9">
            <div class="account-advert-block account-block">
                        
                       {% for flashMessage in app.session.flashbag.get('notice') %}
                            <div class="notice-message">
                                {{ flashMessage | raw }}
                            </div>                             
                        {% endfor %}
                        <div class="account-advert-block-content">
                            <div class="row advert-category-adverts">
                                <div class="col-lg-12 col-md-12">
                                    <div class="accountAdverts">
                                        <div class="accountAdvert">
                                            <div class="accountAdvertInfoLeft">
                                                <div class="accountAdvertImage">
                                                    <img src="{{ asset('bundles/Default/img/advert/auto.png') }}" alt="" title="" />
                                                    <div class="accountAdvertInfoViews">{% trans %}Просмотров{% endtrans %}: 128</div>
                                                </div>
                                                <div class="accountAdvertInfo">
                                                    <div class="accountAdvertInfoName">Jeep Compass II</div>
                                                    <div class="accountAdvertInfoBoard">
                                                        <div class="accountAdvertInfoBoardItem">Внедорожник 5 дв.</div>
                                                    </div>
                                                    <div class="accountAdvertInfoModification">
                                                        <div class="accountAdvertInfoModificationItem">
                                                            2.4 л / 175 л.с. / Автомат
                                                        </div>
                                                        <div class="accountAdvertInfoModificationItem">
                                                            Полный привод
                                                        </div>
                                                        <div class="accountAdvertInfoModificationItem">
                                                            Механика
                                                        </div>
                                                        <div class="accountAdvertInfoModificationItem">
                                                            Белый
                                                        </div>
                                                    </div>
                                                    <div class="accountAdvertInfoCity">
                                                        <svg width="11" height="14" viewBox="0 0 11 14" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-right: 9px;">
                                                            <path d="M5.5 3.38135C5.10444 3.38135 4.71776 3.4946 4.38886 3.70679C4.05996 3.91897 3.80362 4.22056 3.65224 4.57341C3.50087 4.92626 3.46126 5.31452 3.53843 5.68911C3.6156 6.06369 3.80608 6.40777 4.08579 6.67783C4.36549 6.94789 4.72186 7.1318 5.10982 7.20631C5.49778 7.28082 5.89991 7.24258 6.26537 7.09643C6.63082 6.95027 6.94318 6.70276 7.16294 6.38521C7.3827 6.06765 7.5 5.6943 7.5 5.31238C7.5 4.80024 7.28929 4.30907 6.91421 3.94693C6.53914 3.5848 6.03043 3.38135 5.5 3.38135ZM5.5 6.2779C5.30222 6.2779 5.10888 6.22127 4.94443 6.11518C4.77998 6.00909 4.65181 5.85829 4.57612 5.68187C4.50043 5.50544 4.48063 5.31131 4.51922 5.12402C4.5578 4.93673 4.65304 4.76469 4.79289 4.62966C4.93275 4.49463 5.11093 4.40267 5.30491 4.36542C5.49889 4.32816 5.69996 4.34728 5.88268 4.42036C6.06541 4.49344 6.22159 4.61719 6.33147 4.77597C6.44135 4.93475 6.5 5.12142 6.5 5.31238C6.5 5.56845 6.39464 5.81404 6.20711 5.99511C6.01957 6.17618 5.76522 6.2779 5.5 6.2779Z" fill="#616161"/>
                                                            <path d="M5.5 0.00195312C4.04131 0.00195313 2.64236 0.561434 1.61091 1.55732C0.579463 2.5532 0 3.90391 0 5.3123C0 9.85506 5 13.2875 5.215 13.4323L5.5 13.6254L5.785 13.4323C6 13.2875 11 9.85506 11 5.3123C11 3.90391 10.4205 2.5532 9.38909 1.55732C8.35764 0.561434 6.95869 0.00195313 5.5 0.00195312ZM5.5 12.433C4.465 11.6509 1 8.76402 1 5.3123C1 4.15998 1.47411 3.05485 2.31802 2.24004C3.16193 1.42523 4.30653 0.96747 5.5 0.96747C6.69347 0.96747 7.83807 1.42523 8.68198 2.24004C9.52589 3.05485 10 4.15998 10 5.3123C10 8.76402 6.535 11.6509 5.5 12.433Z" fill="#616161"/>
                                                        </svg>
                                                        Seville
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="accountAdvertInfoRight">
                                                <div class="accountAdvertInfoNumbers">
                                                    <div class="accountAdvertInfoPrice">20 000 &euro;</div>
                                                    <div class="accountAdvertInfoYear">2017</div>
                                                    <div class="accountAdvertInfoProbeg">120000 {% trans %}км{% endtrans %}</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    {% if products %}
                                        <div class="premium-adverts">
                                            {% for product in products %}
                                                <div class="advert-frame" id="advert_frame_{{ product.id}}">
                                                    {% if locale.isDefault %}
                                                        {% set href = path('product', {'productId' : product.id,'productName' : product.translit}) %}
                                                    {% else %}
                                                        {% set href = path('productLocale', {'_locale' : locale.code,'productId' : product.id,'productName' : product.translit})%}
                                                    {% endif %}
                                                    {% include 'DashboardCommonBundle:Parts:product.html.twig' with {'product' : product, 'locale' : locale, 'href' : href} %}
                                                    <div class="advert-functions-block">
                                                        <ul class="list-unstyled advert-functions-list">
                                                            <li>{% trans %}Tas paliek{% endtrans %} <strong>{{ product.term - product.calculateDaysLeft }} {% trans %}dienas{% endtrans %}</strong></li>
                                                            {% if product.isActive == 0 and product.isConfirm == 1 and product.isCorrect == 0 %}
                                                                <li>
                                                                    {% if locale.isDefault %}
                                                                        <a href="{{ path('account_switchonproduct', {'productId' : product.id}) }}">{% trans %}Pagarināt{% endtrans %}</a>
                                                                    {% else %}
                                                                        <a href="{{ path('account_switchonproductLocale', {'productId' : product.id,'_locale' : locale.code}) }}">{% trans %}Pagarināt{% endtrans %}</a>
                                                                    {% endif %}
                                                                </li>
                                                            {% endif %}
                                                            <li>
                                                                {% if locale.isDefault %}
                                                                    <a href="{{ path('editproduct', {'productId' : product.id}) }}">{% trans %}Rediģēt{% endtrans %}</a>
                                                                {% else %}
                                                                    <a href="{{ path('editproductLocale', {'productId' : product.id,'_locale' : locale.code}) }}">{% trans %}Rediģēt{% endtrans %}</a>
                                                                {% endif %}
                                                            </li>
                                                            <li class="advert-functions-list-additional">
                                                                <a href="" class="other">- {% trans %}STILL{% endtrans %} -</a>
                                                                <div class="advert-functions-list-additional-block">
                                                                    <table>
                                                                        <!--{% if product.isConfirm == 1 %}
                                                                            {% if services %}
                                                                                {% for service in services %}
                                                                                    <tr>
                                                                                        <td class="blue">{{ service.icon | raw }}</td>
                                                                                        <td>
                                                                                            {% if locale.isDefault %}
                                                                                                <a href="{{ path('account_service', {'serviceId' : service.id,'productId' : product.id}) }}">
                                                                                            {% else %}
                                                                                                <a href="{{ path('account_serviceLocale', {'serviceId' : service.id,'productId' : product.id,'_locale' : locale.code}) }}">
                                                                                            {% endif %}

                                                                                                {% if service.translations | length > 0 %}
                                                                                                    {% for translation in service.translations %}
                                                                                                        {% if translation.locale.id == locale.id %}
                                                                                                            {{ translation.value }}
                                                                                                        {% endif %}
                                                                                                    {% endfor %}
                                                                                                {% else %}
                                                                                                    {{ service.title }}
                                                                                                {% endif %}
                                                                                            </a>
                                                                                        </td>
                                                                                    </tr>    
                                                                                {% endfor %}
                                                                            {% endif %}
                                                                        {% endif %}-->
                                                                        <tr>
                                                                            {% if product.isActive and not product.isBlocked  %}
                                                                                <td class="red"><i class="fa fa-times" aria-hidden="true"></i></td>
                                                                                <td>
                                                                                    {% if locale.isDefault %}
                                                                                        <a href="{{ path("account_products", {'productId' : product.id }) }}" onclick="if(confirm('{% trans %}Vai tiešām vēlaties noņemt šo reklāmu{% endtrans %}?')){return true;}else {return false;}">{% trans %}Izņem no pārdošanas{% endtrans %}</a>
                                                                                    {% else %}
                                                                                        <a href="{{ path("account_productsLocale", {'productId' : product.id,'_locale' : locale.code }) }}" onclick="if(confirm('{% trans %}Vai tiešām vēlaties noņemt šo reklāmu{% endtrans %}?')){return true;}else {return false;}">{% trans %}Izņem no pārdošanas{% endtrans %}</a>
                                                                                    {% endif %}

                                                                                </td>
                                                                            {% else %}
                                                                                <td class="red"><i class="fa fa-times" aria-hidden="true"></i></td>
                                                                                <td>
                                                                                    {% if locale.isDefault %}
                                                                                        <a href="{{ path('account_products_blocked', {'productId' : product.id}) }}" onclick="if(confirm('{% trans %}Vai tiešām vēlaties noņemt šo reklāmu{% endtrans %}?')){return true;}else {return false;}">{% trans %}Noņemt{% endtrans %}</a>
                                                                                    {% else %}
                                                                                        <a href="{{ path("account_products_blocked", {'productId' : product.id,'_locale' : locale.code }) }}" onclick="if(confirm('{% trans %}Vai tiešām vēlaties noņemt šo reklāmu{% endtrans %}?')){return true;}else {return false;}">{% trans %}Izņem no pārdošanas{% endtrans %}</a>
                                                                                    {% endif %}
                                                                                </td>
                                                                            {% endif %}
                                                                        </tr>
                                                                    </table>
                                                                </div>
                                                            </li>
                                                        </ul>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </div>   
                                    {% else %}
                                        <div class="account-block-content-notfound">
                                            {% trans %}Jūs vēl neesat pievienojis nevienu reklāmu{% endtrans %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="account-selected-advert-block account-block">
                        <div class="account-block-header"><h1>{% trans %}Piedāvātās reklāmas{% endtrans %}</h1>
                            {% if favProducts | length > 4 %}
                            <div class="account-block-header-label">
                                <a href="{{ path('account_favproducts') }}">{% trans %}parādīt visu{% endtrans %} ({{ favProducts | length }})</a>
                            </div>
                            {% endif %}
                        </div>
                        <div class="account-selected-advert-block-content">
                            <div class="row advert-category-adverts">
                                <div class="col-lg-12 col-md-12">
                                    {% if favProducts %}
                                        <div class="premium-adverts">
                                            {% for product in favProducts %}
                                                <div class="advert-frame" id="advert_frame_{{ product.id}}">
                                                    {% if locale.isDefault %}
                                                        {% set href = path('product', {'productId' : product.id,'productName' : product.translit}) %}
                                                    {% else %}
                                                        {% set href = path('productLocale', {'_locale' : locale.code,'productId' : product.id,'productName' : product.translit})%}
                                                    {% endif %}
                                                    {% include 'DashboardCommonBundle:Parts:product.html.twig' with {'product' : product, 'locale' : locale, 'href' : href} %}
                                                    <div class="advert-functions-block">
                                                        <ul class="list-unstyled advert-functions-list">
                                                            <li>
                                                                {% if locale.isDefault %}
                                                                    <a onclick="if(confirm('{% trans %}Vai tiešām vēlaties noņemt šo reklāmu no izlases{% endtrans %}?'))return true;else return false;" href="{{ path('account_favproducts',{'productId' : product.id}) }}">{% trans %}Noņemt no izlases{% endtrans %}</a>
                                                                {% else %}
                                                                    <a onclick="if(confirm('{% trans %}Vai tiešām vēlaties noņemt šo reklāmu no izlases{% endtrans %}?'))return true;else return false;" href="{{ path('account_favproductsLocale',{'productId' : product.id, '_locale' : locale.code}) }}">{% trans %}Noņemt no izlases{% endtrans %}</a>
                                                                {% endif %}
                                                            </li>
                                                        </ul>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </div>  
                                    {% else %}
                                        <div class="account-block-content-notfound">{% trans %}Jūs vēl neesat pievienojis nevienu reklāmu{% endtrans %}</div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="account-messages-block account-block">
                        <div class="account-block-header"><h1>{% trans %}Amati{% endtrans %}</h1></div>
                        <div class="account-messages-block-content">
                            {% if messages %}
                                <div class="row account-messages-block-previews">
                                    {% include 'DashboardCommonBundle:Parts:messageitem.html.twig' with {'messages' : messages, 'locale' : locale} %}
                                </div>
                            {% else %}
                                <div class="account-block-content-notfound">{% trans %}Nav jaunu ziņojumu{% endtrans %}</div>
                            {% endif%}
                        </div>
                    </div>
                </div>
    </div>
</div>
{% endblock%}