{% extends 'DashboardCommonBundle:Common:base.html.twig' %}

{% block title %}{% trans %}Личный кабинет{% endtrans %} - {% trans %}Черный список{% endtrans %}{% endblock %}
{% block bodyClass %}class="userAccount"{% endblock %}
{% block body %}
<nav class="breadscrumbsBlock">
      <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <ul class="list-unstyled list-inline breadscrumbs">
                    {% if locale.isDefault %}
                        <li><a href="{{ path('main') }}">{% trans %}Главная{% endtrans %}</a></li>
                        <li>/</li>
                    {% else %}
                        <li><a href="{{ path('mainLocale',{'_locale' : app.request.locale}) }}">{% trans %}Главная{% endtrans %}</a></li>
                        <li>/</li>
                    {% endif %}
                    {% if  locale.isDefault %}
                        <li><a href="{{ path('account', {'_locale' : locale.code}) }}">
                    {% else %}
                        <li><a href="{{ path('accountLocale', {'_locale' : locale.code}) }}">
                    {% endif %}
                        {% trans %}Личный кабинет{% endtrans %}
                    </a></li>
                    <li>/</li>
                    <li>
                    {% if  locale.isDefault %}
                        <a href="{{path('account_bills')}}">
                    {% else %}
                        <a href="{{path('account_billsLocale',{'_locale' : app.request.locale})}}">
                    {% endif %}
                        {% trans %}Финансы{% endtrans %}
                    </a></li>
                </ul>
            </div>
        </div>
      </div>
</nav>
<div class="container">
    <div class="row content-row aligned">
        <div class="col-lg-2 col-md-2">
            <div class="account-block-header"><h1>{% trans %}Личный кабинет{% endtrans %}</h1></div>
        </div>
        <div class="col-lg-10 col-md-10">
            <div class="accountBlockHeader">
                <div class="account-block-header"><h1><b>{% trans %}Финансы{% endtrans %}</b></h1></div>
            </div>
        </div>
    </div>
    <div class="row content-row">
        {{ render(controller('DashboardCommonBundle:Account:getSidebar',{'routeName' : routeName})) }}
        <div class="col-lg-10 col-md-10">
            <div class="account-advert-block-content">
                {% if bills %}
                    <div class="accountBills">
                        {% for bill in bills %}
                            <div class="accountBill">
                                <div class="accountBillInfo">
                                    <div class="accountBillInfoItem date">21.12.2019 в 22.01</div>
                                    <div class="accountBillInfoItem title">Счет №1234</div>
                                    <div class="accountBillInfoItem price">10.99€</div>
                                </div>
                                <div class="accountBillDownload">
                                    <svg width="26" height="32" viewBox="0 0 26 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M7 1L1 7V31H25V1H7Z" stroke="#616161" stroke-width="2" stroke-linejoin="round"/>
                                        <path d="M7 1V7H1" stroke="#616161" stroke-width="2" stroke-linejoin="round"/>
                                        <path d="M20 14H6V26H20V14Z" stroke="#616161" stroke-width="2" stroke-linejoin="round"/>
                                        <path d="M6 19H20" stroke="#616161" stroke-width="2" stroke-linejoin="round"/>
                                        <path d="M11 14V26" stroke="#616161" stroke-width="2" stroke-linejoin="round"/>
                                    </svg>
                                    <a href="">Скачать счет</a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="accountNocontent">{% trans %}Нет ни одного счета{% endtrans %}</div> 
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}