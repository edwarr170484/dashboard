                                           </li><li>
                                               <div class="workDay workingDay weekDay {% if formDealer.workinfo.thursday.vars.checked %}active{% endif %}" onclick="$(this).toggleClass('active');">
                                                    {{ form_widget(formDealer.workinfo.thursday) }}
                                                    {{ form_label(formDealer.workinfo.thursday) }}
                                               </div>
                                           </li><li>
                                               <div class="workDay workingDay weekDay {% if formDealer.workinfo.friday.vars.checked %}active{% endif %}" onclick="$(this).toggleClass('active');">
                                                    {{ form_widget(formDealer.workinfo.friday) }}
                                                    {{ form_label(formDealer.workinfo.friday) }}
                                               </div>
                                           </li><li>
                                               <div class="workDay holidayDay weekDay {% if formDealer.workinfo.saturday.vars.checked %}active{% endif %}" onclick="$(this).toggleClass('active');">
                                                    {{ form_widget(formDealer.workinfo.saturday) }}
                                                    {{ form_label(formDealer.workinfo.saturday) }}
                                               </div>
                                           </li><li>
                                               <div class="workDay holidayDay weekDay {% if formDealer.workinfo.sunday.vars.checked %}active{% endif %}" onclick="$(this).toggleClass('active');">
                                                    {{ form_widget(formDealer.workinfo.sunday) }}
                                                    {{ form_label(formDealer.workinfo.sunday) }}
                                                    {{ form_widget(formDealer.workinfo.dealer) }}
                                               </div>
                                           </li>
                                           <li class="allDay">
                                               <div class="workDay {% if formDealer.workinfo.fullDay.vars.checked %}active{% endif %}" onclick="resetWorkTimes($(this),$('.dealerWorkdays'))">
                                                    {{ form_widget(formDealer.workinfo.fullDay) }}
                                                    {{ form_label(formDealer.workinfo.fullDay) }}
                                               </div>
                                           </li><li>
                                               {{ form_widget(formDealer.workinfo.workStart) }}
                                           </li><li class="space"> - </li><li>
                                               {{ form_widget(formDealer.workinfo.workStop) }}
                                           </li>
                                       </ul>
                                       <ul class="list-unstyled list-inline workdays dealerWorkdays">
                                           <li style="padding-right: 10px;">
                                               <div class="workDay selectDaysButton {% if formDealer.workinfo.isWokdays.vars.checked %}active{% endif %}" onclick="selectWeekDays($(this), $('#weekdays'), '.workingDay')">
                                                    {{ form_widget(formDealer.workinfo.isWokdays) }}
                                                    {{ form_label(formDealer.workinfo.isWokdays) }}
                                               </div>
                                           </li><li style="padding-right: 10px;">
                                               <div class="workDay selectDaysButton {% if formDealer.workinfo.isHolidays.vars.checked %}active{% endif %}" onclick="selectWeekDays($(this), $('#weekdays'), '.holidayDay')">
                                                    {{ form_widget(formDealer.workinfo.isHolidays) }}
                                                    {{ form_label(formDealer.workinfo.isHolidays) }}
                                               </div>
                                           </li><li style="padding-right: 24px;">
