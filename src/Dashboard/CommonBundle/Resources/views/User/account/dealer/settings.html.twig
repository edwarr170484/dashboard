                                            <script>
                                                $(document).ready(function(){
                                                    var prototype = $("#dealerinfo_phones").data("prototype");
                                                    var count = $(".dealerPhonesItem").length;
                                                    var newForm = prototype.replace(/__name__/g, count);
                                                    $(".dealerPhonesList").append(newForm);
                                                });
                                            </script>
                                        {% endif %}
                                        <button id="addDealerPhone" type="button">
                                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M1 10.9998H21M11 0.999817V20.9998V0.999817Z" stroke="#747474" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="formParemetersItem" style="padding-bottom: 3rem;">
                                <div class="formParameter">
                                    <div class="formParameterLabel">{{ form_label(formDealer.logotypeNew) }}:</div>
                                    <div class="formParameterField dealerLogoField dealerLogotype">
                                        <a class="change-avatar logotype" onclick='$(this).parent().find(".change-avatar-input").trigger("click");'>
                                            <svg width="126" height="126" viewBox="0 0 126 126" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <rect x="0.5" y="0.5" width="125" height="125" rx="4.5" stroke="#DFE1E5"/>
                                                <rect x="3.5" y="3.5" width="119" height="119" rx="4.5" stroke="#F5AA01" stroke-dasharray="12 6"/>
                                                <circle cx="63" cy="63" r="27.5" stroke="#F5AA01" stroke-width="3"/>
                                                <line x1="47" y1="63.5" x2="79" y2="63.5" stroke="#F5AA01" stroke-width="3"/>
                                                <line x1="62.5" y1="79" x2="62.5" y2="47" stroke="#F5AA01" stroke-width="3"/>
                                            </svg>
                                        </a>
                                        {% if formDealer.logotype.vars.value %}
                                            <div class="dealerSettingsLogotype">
                                                <img src="{{ asset('bundles/images/dealers/logotypes/' ~ formDealer.logotype.vars.value) }}" alt="" title="" />
                                                <div class="dealerSettingsLogotypeCover">
                                                    <button type="button" onclick="deleteDealerLogotype('{% trans %}Удалить логотип?{% endtrans %}')">{% trans %}Удалить{% endtrans %}</button>
                                                </div>
                                            </div>
                                        {% endif %}
                                        {{ form_widget(formDealer.logotypeNew) }}
                                        {{ form_widget(formDealer.logotype) }}
                                        <script>
                                            $("#dealerinfo_logotypeNew").change(function(){
                                                var fd = new FormData;
                                                $("#dealerinfo").find("input[type='text']").each(function(){
                                                    fd.append($(this).attr('name'), $('#' + $(this).attr('id')).val());
                                                });
                                                $("#dealerinfo").find("input[type='email']").each(function(){
                                                    fd.append($(this).attr('name'), $('#' + $(this).attr('id')).val());
                                                });
                                                $("#dealerinfo").find("select").each(function(){
                                                    fd.append($(this).attr('name'), $('#' + $(this).attr('id')).val());
                                                });
                                                $("#dealerinfo").find("input[type='hidden']").each(function(){
                                                    fd.append($(this).attr('name'), $('#' + $(this).attr('id')).val());
                                                });
                                                $("#dealerinfo").find("textarea").each(function(){
                                                    fd.append($(this).attr('name'), $('#' + $(this).attr('id')).val());
                                                });
                                                $("#dealerinfo").find("input[type='file']").each(function(){
                                                    fd.append($(this).attr('name'), $('#' + $(this).attr('id'))[0].files[0]);
                                                });
                                                //fd.append('dealerinfo[logotypeNew]', $('#dealerinfo_logotypeNew')[0].files[0]);
                                                
                                                $.ajax({
                                                    url:'/account/settings',
                                                    data: fd,
                                                    processData: false,
                                                    contentType: false,
                                                    method: 'post',
                                                    success : function(html){
                                                        $('.dealerLogotype').html($(html).find('.dealerLogotype').html());
                                                    }
                                                });
                                            });
                                        </script>
                                    </div>
                                </div>
                            </div>
                            <div class="formParemetersItem" style="padding-bottom: 6rem;">
                                <div class="formParameter" style="display: block;">
                                   <div class="formParameterLabel">{% trans %}Режим работы{% endtrans %}: <sup>*</sup></div>
                                   <div class="formParameterField">{{ form_label(formDealer.workinfo) }}
