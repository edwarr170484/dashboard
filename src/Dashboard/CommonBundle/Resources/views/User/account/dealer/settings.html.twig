                                <div class="formParameter">
                                    <div class="formParameterLabel">{{ form_label(formDealer.firma) }}: <sup>*</sup></div>
                                    <div class="formParameterField">
                                        {{ form_widget(formDealer.firma) }}
                                    </div>
                                </div>
                                <div class="formParameter">
                                    <div class="formParameterLabel">{{ form_label(formDealer.company) }}: <sup>*</sup></div>
                                    <div class="formParameterField">
                                        {{ form_widget(formDealer.company) }}
                                    </div>
                                </div>
                            </div>
                            <div class="formParemetersItem">
                                <div class="formParameter">
                                    <div class="formParameterLabel">{{ form_label(formDealer.nifNumber) }}: <sup>*</sup></div>
                                    <div class="formParameterField">
                                        {{ form_widget(formDealer.nifNumber) }}
                                    </div>
                                </div>
                                <div class="formParameter">
                                    <div class="formParameterLabel">{{ form_label(formDealer.website) }}:</div>
                                    <div class="formParameterField">
                                        {{ form_widget(formDealer.website) }}
                                    </div>
                                </div>
                            </div>
                            <div class="formParemetersItem">
                                <div class="formParameter">
                                    <div class="formParameterLabel">{% trans %}Индекс{% endtrans %}:</div>
                                    <div class="formParameterField cityCodeBlock">
                                        {{ form_widget(formDealer.cityCode,{'id' : 'dealerCityCode'})}}
                                        <div class="codesListBlock"></div>
                                    </div>
                                </div>
                                <div class="formParameter">
                                    <div class="formParameterLabel">{% trans %}Город{% endtrans %}: <sup>*</sup></div>
                                    <div class="formParameterField">
                                        {{ form_widget(formDealer.city,{'id' : 'dealerCity'})}}
                                    </div>
                                </div>
                                <script>
                                    $("#dealerCityCode").keyup(function(){
                                        var len = $(this).val().length;
                                        var element = $(this);
                                        if(len === 5){
                                            $.ajax({
                                                url : '/region/getcity/' + $(this).val(),
                                                type: 'get',
                                                dataType: 'json',
                                                success: function(data) {
                                                    if(data !== 0){
                                                        $("#dealerCity").parent().find(".select-option").each(function(){
                                                            if($(this).data('value') === parseInt(data.city)){
                                                                $(this).trigger('click');
                                                                $("#dealerCity").val(data.city);
                                                                $("#dealerCityCode").val(data.code);
                                                            }
                                                        });
                                                    }
                                                }
                                            });
                                        }else{
                                            $.ajax({
                                                url : '/region/getcodes/' + $(this).val(),
                                                type: 'get',
                                                dataType: 'html',
                                                success: function(data) {
                                                    element.parent().find('.codesListBlock').html(data).show();
                                                }
                                            });
                                        }
                                    });
                                    
                                    $("#dealerCity").change(function(){
                                        $("#dealerCityCode").val(null);
                                        $(".codesListBlock").html('').hide();
                                    });
                                </script>
                            </div>
                            <div class="formParemetersItem">
                                <div class="formParameter">
                                    <div class="formParameterLabel">{{ form_label(formDealer.address) }}: <sup>*</sup></div>
                                    <div class="formParameterField">
                                        {{ form_widget(formDealer.address) }}
                                    </div>
                                </div>
                                <div class="formParameter">
                                    <div class="formParameterLabel">{{ form_label(formDealer.email) }}: <sup>*</sup></div>
                                    <div class="formParameterField">
                                        {{ form_widget(formDealer.email) }}
                                    </div>
                                </div>
                            </div>
                            <div class="formParemetersItem">
