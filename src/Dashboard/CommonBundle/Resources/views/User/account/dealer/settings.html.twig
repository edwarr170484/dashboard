                                                    {{ form_widget(formDealer.workinfo.tuesday) }}
                                                    {{ form_label(formDealer.workinfo.tuesday) }}
                                               </div>
                                           </li><li>
                                               <div class="workDay workingDay weekDay {% if formDealer.workinfo.wednesday.vars.checked %}active{% endif %}" onclick="$(this).toggleClass('active');">
                                                    {{ form_widget(formDealer.workinfo.wednesday) }}
                                                    {{ form_label(formDealer.workinfo.wednesday) }}
