                                    {% for salon in user.dealerinfo.salons %}
                                        <div class="mapListItem" id="dealerSalon{{ salon.id }}">
                                            <div class="mapListItemImage">
                                                <div class="mapListItemImageSrc">
                                                    <img src="{{ asset('bundles/images/dealers/salons/' ~ salon.logotype) }}" alt="{{ salon.name }}" title="{{ salon.name }}" />
                                                </div>
                                            </div>
                                            <div class="mapListItemInfo">
                                                <div class="mapListItemInfoName">{{ salon.name }}</div>
