{% extends 'DashboardCommonBundle:Common:base.html.twig' %}

{% form_theme formMain _self %}
{% form_theme formPassword _self %}
{% form_theme formDealer _self %}
{% form_theme formAutos _self %}
{% form_theme formDealerSalon _self %}

{%- block form_widget_simple -%}
    {%- set type = type|default('text') -%}
    <input type="{{ type }}" {{ block('widget_attributes') }} {% if value is not empty %}value="{{ value }}" {% endif %}/>
{%- endblock form_widget_simple -%}

{%- block button_row -%}
    <button class="message-button-answer" type="submit">{{form_label(form)}}</button>
{%- endblock button_row -%}

{% block _dealerinfo_phones_widget %}
    <div class="dealerPhonesList">
        {{ form_widget(form) }}
    </div>
{% endblock %}

{% block _dealerinfo_phones_entry_row %}
    <div class="dealerPhonesItem">
        {{ form_widget(form.phone)}}
        {{ form_widget(form.dealerInfo)}}
    </div>
{% endblock %}

{% block _dealersalon_phones_widget %}
    <div class="dealerSalonPhonesList">
        {{ form_widget(form) }}
    </div>
{% endblock %}

{% block _dealersalon_phones_entry_row %}
    <div class="dealerSalonPhonesItem">
        {{ form_widget(form.phone)}}
        {{ form_widget(form.dealerSalon)}}
    </div>
{% endblock %}

{%- block form_label -%}
    {% if label is not same as(false) -%}
        {% if not compound -%}
            {% set label_attr = label_attr|merge({'for': id}) %}
        {%- endif -%}
        {% if required -%}
            {% set label_attr = label_attr|merge({'class': (label_attr.class|default('') ~ ' required')|trim}) %}
        {%- endif -%}
        {% if label is empty -%}
            {%- if label_format is not empty -%}
                {% set label = label_format|replace({
                    '%name%': name,
                    '%id%': id,
                }) %}
            {%- else -%}
                {% set label = name|humanize %}
            {%- endif -%}
        {%- endif -%}
        {{ translation_domain is same as(false) ? label : label|trans({}, translation_domain) }}
    {%- endif -%}
{%- endblock form_label -%}

{% block title %}{% trans %}Личный кабинет{% endtrans %} - {% trans %}Настройки{% endtrans %}{% endblock %}
{% block bodyClass %}class="userAccount"{% endblock %}
{% block body %}
<nav class="breadscrumbsBlock">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <ul class="list-unstyled list-inline breadscrumbs">
                    <li><a href="{{ path('main') }}">{% trans %}Главная{% endtrans %}</a></li>
                    <li>/</li>
                    {% if user.roles[0].role != 'ROLE_SERVICE' %}
                        <li><a href="{{ path('account') }}">{% trans %}Личный кабинет{% endtrans %}</a></li>
                        <li>/</li>
                    {% endif %}
                    <li>{% trans %}Настройки{% endtrans %}</li>
                </ul>
            </div>
        </div>
        <button id="breadScrumbsMobileMenuToggler">{% trans %}Меню{% endtrans %}</button>
    </div>
</nav> 
<div class="container">
