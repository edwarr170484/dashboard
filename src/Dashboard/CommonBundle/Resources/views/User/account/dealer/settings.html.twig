                        <a class="nav-link" id="home-tab" data-toggle="tab" href="#alertSettings" role="tab" aria-controls="home" aria-selected="true" >{% trans %}Настройка уведомлений{% endtrans %}</a>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade active in" id="companySettings" role="tabpanel">
                        {{ form_start(formDealer, {'method':'POST', 'multipart':true,'attr': {'id' : 'dealerinfo','class': 'form-horizontal userSettingsForm'}}) }}
                        <div class="accountBlockHeader subheader">
                            <div class="account-block-header"><h1><b>{% trans %}Данные компании{% endtrans %}</b></h1></div>
                        </div>
                        <div class="accountSettingsFormBlock">
