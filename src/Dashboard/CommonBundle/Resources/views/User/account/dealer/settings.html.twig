                                        {% if user.dealerInfo.autos | length > 0 %}
                                            <div class="dealerAutoList">
                                                {% for auto in user.dealerInfo.autos %}
                                                    <div class="dealerAutoListItem">
                                                        {{ auto.image | raw }}
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                        <div class="dealerAutoButton">
                                            <button data-toggle="modal" data-target="#dealerAutoMarksModal" type="button">Выбор марки</button>
                                        </div>
                                    </div>
                                </div>
                            </div>            
                        </div>
                        <div class="accountBlockHeader subheader">
                            <div class="account-block-header"><h1><b>{% trans %}Фотогалерея{% endtrans %}</b></h1></div>
                        </div>
                        <div class="accountSettingsFormBlock">
                        <table class="table" id="dealerFotoTable">    
                            <tbody>
                                <tr class="addAdvertFotoBlock">
                                    <td style="vertical-align: top;"><div class="advertFiltersItemName" style="padding-left: 0;margin: 0;">{% trans %}Фотографии{% endtrans %}</div></td>
                                    <td>
                                        <div class="advertFiltersItemValue fotos" id="advertFotos">
                                            <div class="advertFotosStartBg">
                                                <div class="addFotoIcon"><div class="addFotoIconInner"></div></div><div class="addFotoDescription">{% trans %}Кликните для загрузки изображений, можно выбрать несколько. Общее количество изображений не должно превышать 30.{% endtrans %}</div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        </div>
                        <div class="accountBlockHeader subheader">
                            <div class="account-block-header"><h1><b>{% trans %}Описание компании{% endtrans %}</b></h1></div>
                        </div>
                        <div class="accountSettingsFormBlock">
                            <div class="formParemetersItem">
                                <div class="formParameter" style="align-items:flex-start">
                                    <div class="formParameterLabel">{{ form_label(formDealer.description) }}: <sup>*</sup>
                                        <span>{% trans %}Не более 2000 знаков{% endtrans %}</span>
                                    </div>
                                    <div class="formParameterField">
                                        {{ form_widget(formDealer.description) }}
                                        <div class="addAdvertParameterDescription">
                                            <div class="addAdvertParameterDescriptionTitle">{% trans %}О чем стоит написать{% endtrans %}:</div>
                                            <div class="addAdvertParameterDescriptionText">
                                                <ul class="list-unstyled">
                                                    <li>- напишите чем занимается Ваша компания,</li>
                                                    <li>- ваши преимущества и другую информацию которая может заинтересовать</li>
                                                    <li>вашего потенциального клиента</li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="formParemetersItem">
                                <div class="formParameter">
                                    <div class="formParameterLabel"></div>
                                    <div class="formParameterField cookieAlertButton">
                                        {{ form_widget(formDealer.save,{'type' : 'submit'})}}
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{ form_end(formDealer) }}
                    </div>
                    <div class="tab-pane fade" id="companyShops" role="tabpanel">
