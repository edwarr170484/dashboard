                            <div class="accountSettingsFormBlockHeader">{% trans %}Если у Вас есть автосалоны по продаже автомобилей, Вы можете добавить их здесь{% endtrans %}.</div>
                            <div class="cookieAlertButton">
                                <button data-toggle="modal" data-target="#dealerAutoSalonsModal" type="button">+ {% trans %}Добавить автосалон{% endtrans %}</button>
                            </div>
