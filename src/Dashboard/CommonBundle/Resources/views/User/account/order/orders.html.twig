                                                        {% else %}
                                                            {% trans %}Lietotājs ir dzēsts{% endtrans %}
                                                        {% endif %}
                                                    </div>
                                                    <div><strong>Email:</strong> {{ order.email }}</div>
                                                    <div><strong>{% trans %}Tālruņa numurs{% endtrans %}:</strong> {{ order.phone }}</div>
                                                    {% if order.comment %}
