<div class="accountAdvert cube" id="favoriteProduct{{ product.id }}">
    <div class="accountAdvertLikeButton">
        <button onclick="showNoteForm({{ product.id }}, {% if user %}1{% else %}0{% endif %})">
            <svg width="19" height="23" viewBox="0 0 19 23" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M11.4512 1.00195H3.45117C2.92074 1.00195 2.41203 1.21267 2.03696 1.58774C1.66189 1.96281 1.45117 2.47152 1.45117 3.00195V19.002C1.45117 19.5324 1.66189 20.0411 2.03696 20.4162C2.41203 20.7912 2.92074 21.002 3.45117 21.002H15.4512C15.9816 21.002 16.4903 20.7912 16.8654 20.4162C17.2405 20.0411 17.4512 19.5324 17.4512 19.002V7.00195L11.4512 1.00195Z" fill="#F5AA01"/>
                <path d="M11.4512 1.00195V7.00195H17.4512" fill="#F5AA01"/>
                <path d="M11.4512 1.00195H3.45117C2.92074 1.00195 2.41203 1.21267 2.03696 1.58774C1.66189 1.96281 1.45117 2.47152 1.45117 3.00195V19.002C1.45117 19.5324 1.66189 20.0411 2.03696 20.4162C2.41203 20.7912 2.92074 21.002 3.45117 21.002H15.4512C15.9816 21.002 16.4903 20.7912 16.8654 20.4162C17.2405 20.0411 17.4512 19.5324 17.4512 19.002V7.00195H11.4512V1.00195Z" fill="#F5AA01"/>
                <path d="M11.4512 1.00195H3.45117C2.92074 1.00195 2.41203 1.21267 2.03696 1.58774C1.66189 1.96281 1.45117 2.47152 1.45117 3.00195V19.002C1.45117 19.5324 1.66189 20.0411 2.03696 20.4162C2.41203 20.7912 2.92074 21.002 3.45117 21.002H15.4512C15.9816 21.002 16.4903 20.7912 16.8654 20.4162C17.2405 20.0411 17.4512 19.5324 17.4512 19.002V7.00195M11.4512 1.00195L17.4512 7.00195M11.4512 1.00195V7.00195H17.4512M6.45117 14.002H12.4512" stroke="#616161" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>    
        </button>
    </div>
    <div class="inner">
        <a href="{{ path('product', {'productId' : product.id, 'productName' : product.translit}) }}">
            <div class="accountAdvertImage">
                {% if product.fotos | length > 0 %}
                    <img src="{{ asset('bundles/images/products/' ~ product.fotos[0].foto) }}" alt="{{ product.name }}" title="{{ product.name }}" />
                {% endif %}
            </div>
            <div class="accountAdvertInfoName">{{ product.name }} {% if product.info.modification %}{{ product.info.modification.label }}{% endif %}</div>
            <div class="accountAdvertInfoBoard">
                {% if product.info.board %}
                    <div class="accountAdvertInfoBoardItem">
                        {{ product.info.board.value }}
                    </div>
                {% endif %}
                {% if product.info.shape %}
                    <div class="accountAdvertInfoBoardItem">
                        {{ product.info.shape.title }}
                    </div>
                {% endif %}
            </div>
            <div class="accountAdvertInfoModification">
                <div class="accountAdvertInfoModificationItem">
                    {{ product.info.year }}, {{ product.info.probeg }} {% trans %}км{% endtrans %}
                </div>
                <div class="accountAdvertInfoModificationItem">
                     {% if product.info.modification %}{{ product.info.modification.size }} /  {{ product.info.modification.power }} {% trans %}л.с.{% endtrans %}  / {% endif %} {% if product.info.gasType %} {{ product.info.gasType.value }}{% endif %}
                </div>
                <div class="accountAdvertInfoModificationItem">
                    <svg width="11" height="14" viewBox="0 0 11 14" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-right: 9px;">
                        <path d="M5.5 3.38135C5.10444 3.38135 4.71776 3.4946 4.38886 3.70679C4.05996 3.91897 3.80362 4.22056 3.65224 4.57341C3.50087 4.92626 3.46126 5.31452 3.53843 5.68911C3.6156 6.06369 3.80608 6.40777 4.08579 6.67783C4.36549 6.94789 4.72186 7.1318 5.10982 7.20631C5.49778 7.28082 5.89991 7.24258 6.26537 7.09643C6.63082 6.95027 6.94318 6.70276 7.16294 6.38521C7.3827 6.06765 7.5 5.6943 7.5 5.31238C7.5 4.80024 7.28929 4.30907 6.91421 3.94693C6.53914 3.5848 6.03043 3.38135 5.5 3.38135ZM5.5 6.2779C5.30222 6.2779 5.10888 6.22127 4.94443 6.11518C4.77998 6.00909 4.65181 5.85829 4.57612 5.68187C4.50043 5.50544 4.48063 5.31131 4.51922 5.12402C4.5578 4.93673 4.65304 4.76469 4.79289 4.62966C4.93275 4.49463 5.11093 4.40267 5.30491 4.36542C5.49889 4.32816 5.69996 4.34728 5.88268 4.42036C6.06541 4.49344 6.22159 4.61719 6.33147 4.77597C6.44135 4.93475 6.5 5.12142 6.5 5.31238C6.5 5.56845 6.39464 5.81404 6.20711 5.99511C6.01957 6.17618 5.76522 6.2779 5.5 6.2779Z" fill="#616161"/>
                        <path d="M5.5 0.00195312C4.04131 0.00195313 2.64236 0.561434 1.61091 1.55732C0.579463 2.5532 0 3.90391 0 5.3123C0 9.85506 5 13.2875 5.215 13.4323L5.5 13.6254L5.785 13.4323C6 13.2875 11 9.85506 11 5.3123C11 3.90391 10.4205 2.5532 9.38909 1.55732C8.35764 0.561434 6.95869 0.00195313 5.5 0.00195312ZM5.5 12.433C4.465 11.6509 1 8.76402 1 5.3123C1 4.15998 1.47411 3.05485 2.31802 2.24004C3.16193 1.42523 4.30653 0.96747 5.5 0.96747C6.69347 0.96747 7.83807 1.42523 8.68198 2.24004C9.52589 3.05485 10 4.15998 10 5.3123C10 8.76402 6.535 11.6509 5.5 12.433Z" fill="#616161"/>
                    </svg>
                    {{ product.city.name }}
                </div>
                <div class="accountAdvertInfoPrice">
                    <div class="accountAdvertInfoPriceValue">{{ product.info.price }} {{ locale.currency.label | raw }}</div>
                    <!--<div class="accountAdvertInfoPriceCredit">от 12 500 €/мес.</div>-->
                </div>
            </div>
        </a> 
        <div class="productNoteFormContainer" id="productNoteFormContainer{{ product.id }}">
                {% set noteText = '' %}
                {% if product.notes | length > 0 %}
                    {% for note in product.notes %}
                        {% if note.user.id == user.id %}
                            <div class="productNoteText">
                                <svg width="18" height="23" viewBox="0 0 18 23" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M11 1.00195H3C2.46957 1.00195 1.96086 1.21267 1.58579 1.58774C1.21071 1.96281 1 2.47152 1 3.00195V19.002C1 19.5324 1.21071 20.0411 1.58579 20.4162C1.96086 20.7912 2.46957 21.002 3 21.002H15C15.5304 21.002 16.0391 20.7912 16.4142 20.4162C16.7893 20.0411 17 19.5324 17 19.002V7.00195M11 1.00195L17 7.00195M11 1.00195V7.00195H17M6 14.002H12" stroke="#616161" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <div class="productNoteTextInner">{{ note.text }}</div>
                                <button onclick="deleteProductNote({{ product.id }},'{% trans %}Хотите удалить заметку?{% endtrans %}');">
                                    <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M26 1.4524L24.5476 0L13 11.5578L1.4524 0L0 1.4524L11.5578 13L0 24.5476L1.4524 26L13 14.4422L24.5476 26L26 24.5476L14.4422 13L26 1.4524Z" fill="#616161"/>
                                    </svg>
                                </button>
                            </div> 
                            {% set noteText = note.text %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
                <div class="productNoteForm">
                    <svg width="18" height="23" viewBox="0 0 18 23" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11 1.00195H3C2.46957 1.00195 1.96086 1.21267 1.58579 1.58774C1.21071 1.96281 1 2.47152 1 3.00195V19.002C1 19.5324 1.21071 20.0411 1.58579 20.4162C1.96086 20.7912 2.46957 21.002 3 21.002H15C15.5304 21.002 16.0391 20.7912 16.4142 20.4162C16.7893 20.0411 17 19.5324 17 19.002V7.00195M11 1.00195L17 7.00195M11 1.00195V7.00195H17M6 14.002H12" stroke="#616161" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <input type="text" name="productNoteText{{ product.id }}" placeholder="{% trans %}Заметка об этом объявлении (ее увидите только вы){% endtrans %}" {% if noteText %}value="{{ noteText }}"{% endif %} />
                    <div class="cookieAlertButton">
                        <button onclick="saveProductNote({{ product.id }}, '{% trans %}Поле для заметки пустое. Заполните его{% endtrans %}')">Сохранить</button>
                    </div>
                </div>
        </div>
    </div>
</div>
